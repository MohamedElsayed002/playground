# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment variables — NEVER commit .env!
.env
.env.local
.env.*.local

# Uploads — don't commit user-uploaded files
uploads/images/*
uploads/documents/*
uploads/avatars/*
!uploads/**/.gitkeep

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Testing
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/

# Alembic auto-generated (keep versions/ but not __pycache__)
alembic/versions/__pycache__/
